{
  "name": "mcpaudit",
  "version": "0.1.0",
  "description": "Static analysis security scorecard for MCP (Model Context Protocol) servers",
  "keywords": [
    "mcp",
    "security",
    "static-analysis",
    "audit",
    "model-context-protocol",
    "ai-safety"
  ],
  "license": "MIT",
  "author": "Rahul-sch",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahul-sch/Mcp-Audit.git"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "mcpaudit": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "build:watch": "npm run build -- --watch",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.15.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "degit": "^2.8.4",
    "ora": "^5.4.1",
    "tmp": "^0.2.3"
  },
  "devDependencies": {
    "@types/degit": "^2.8.6",
    "@types/node": "^20.16.0",
    "@types/tmp": "^0.2.6",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
